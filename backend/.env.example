# 应用
APP_NAME=智能运营中心 AI Agent Runtime
APP_ENV=local                          # local | dev | test | prod
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 时区 & 日志
APP_TIMEZONE=Asia/Shanghai
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR

# 数据库
DATABASE_URL=mysql+pymysql://AIOpertionsCenter:12345678@localhost:3306/ioc_ai

# Redis（可选，Sprint1 可禁用）
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# 大模型 API Key（通过环境变量注入，不在代码中硬编码）
# QWEN_API_KEY=
# DEEPSEEK_API_KEY=
# DOUBAO_API_KEY=
