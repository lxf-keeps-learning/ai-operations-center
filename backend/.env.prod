APP_NAME=智能运营中心 AI Agent Runtime
APP_ENV=prod
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=https://your-domain.com
APP_TIMEZONE=Asia/Shanghai
LOG_LEVEL=WARNING
# 生产环境必须通过环境变量注入，不要在此文件中填写真实值
DATABASE_URL=mysql+pymysql://user:password@prod-host:3306/ioc_ai
REDIS_ENABLED=true
REDIS_URL=redis://prod-redis:6379/0
